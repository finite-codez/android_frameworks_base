<?xml version="1.0" encoding="utf-8"?>
<!-- Gradient blur background for status bar (light mode: white) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#B3FFFFFF"  <!-- 70% white -->
                android:endColor="#00FFFFFF"    <!-- fully transparent -->
                android:angle="90"/>
        </shape>
    </item>
</layer-list>
